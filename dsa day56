def verify(arr,ans):
    NoPnts=1
    time=0
    for i in arr:
        if(time+i<=ans):
            time+=i
        else:
            NoPnts+=1
            time=i
    return NoPnts
def findLargestMinDistance(boards:list, k:int):
    # Write your code here
    # Return an integer
    high=sum(boards)
    low=max(boards)
    while(low<=high):
        mid=(low+high)//2
        if(verify(boards,mid)<=k):
            high=mid-1
        else:
            low=mid+1
    return low
    

