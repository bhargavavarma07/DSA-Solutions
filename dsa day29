class Solution:
    def maxLength(self, arr):
        # code here
        d={}
        mx=0
        n=len(arr)
        Sum=0
        for i in range(n):
            Sum+=arr[i]
            if(Sum not in d):
                d[Sum]=i
        Sum=0
        for i in range(n):
            Sum+=arr[i]
            if(Sum==0):
                l=i+1
                if(l>mx):
                    mx=l
            elif(Sum in d.keys()):
                l=i-d[Sum]
                if(l>mx):
                    mx=l
        return mx
----------------------------------
Complexity Analysis:
Time Complexity:O(n),where n is the length of the string
Space complexity:O(1) ,as we are using fixed size hash array and not using any hash array with growing size
