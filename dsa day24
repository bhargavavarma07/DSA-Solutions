code:
class Solution:
    def generate(self, numRows: int) -> List[List[int]]:
        ans=[[1]]
        prev=[]
        for i in range(numRows-1):
            x=[1]
            j,k=0,1
            while(k<=i):
                x.append(prev[j]+prev[k])
                j+=1
                k+=1
            x.append(1)
            prev=x
            ans.append(x)
        return ans

        

