class Solution:
    def canWePlace(self,arr,dist,cows):
        ctcow=1
        last=arr[0]
        for i in range(1,len(arr)):
            if(arr[i]-last>dist):
                ctcow+=1
                last=arr[i]
                if(ctcow==cows):
                    return True
        return False
    def aggressiveCows(self, stalls, k):
        # code here
        stalls.sort()
        low=1
        high=stalls[-1]-stalls[0]
        while(low<=high):
            mid=(low+high)//2
            if(self.canWePlace(stalls,mid,k)):
                low=mid+1
            else:
                high=mid-1
        return high+1
        
