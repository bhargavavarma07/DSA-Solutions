class Solution:
    def reverseWords(self, s: str) -> str:
        l=[]
        x=""
        for i in range(len(s)):
            if(s[i].isalnum() and s[i]!=""):
                x=x+s[i]
            else:
                if(x !=""):
                    l.append(x)
                x=""
        if(x!=""):
            l.append(x)
        ans=""
        print(l)
        for i in range(len(l)-1,-1,-1):
            if(i!=0):
                ans=ans+l[i]+" "
            else:
                ans+=l[i]
        return ans

