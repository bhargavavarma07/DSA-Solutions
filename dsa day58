import heapq
class Solution:
    def minMaxDist(self, stations, k):
        # Code here
        heap=[]
        ct=1
        if(len(stations)==1):
            return 0.00
        for i in range(len(stations)-1):
            dif=stations[i+1]-stations[i]
            sec=dif/ct
            heapq.heappush(heap,(-dif,1,dif))
        for _ in range(k):
            dif,ct,og=heapq.heappop(heap)
            ct+=1
            sec=og/ct
            heapq.heappush(heap,(-sec,ct,og))
        Ans=-heap[0][0]
        return Ans
