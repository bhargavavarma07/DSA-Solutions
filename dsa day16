Longest Subarray with Sum K
class Solution:(//brute force)
    def longestSubarray(self, arr, k):  
        # code here
        ans=0
        i=0
        s=0
        ln=0
        for j in range(len(arr)):
            s=0
            for l in range(j,len(arr)):
                s+=arr[l]
                if(s==k):
                    ln=l-j+1
                    if(ln>ans):
                        ans=ln  
        return ans

