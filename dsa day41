class Solution:
    def getFloorAndCeil(self, x: int, arr: list) -> list:
        # code here
        arr.sort()
        l=0
        r=len(arr)-1
        floor=-1
        ceil=-1
        mid=(l+r)//2
        while(l<=r):
            mid=(l+r)//2
            if(arr[mid]<x):
                if(floor==-1):
                    floor=arr[mid]
                floor=max(floor,arr[mid])
                l=mid+1
            elif(arr[mid]>x):
                if(ceil==-1):
                    ceil=arr[mid]
                ceil=min(ceil,arr[mid])
                r=mid-1
            else:
                if(floor==-1):
                    floor=arr[mid]
                if(ceil==-1):
                    ceil=arr[mid]
                floor=max(floor,arr[mid])
                ceil=min(ceil,arr[mid])
                break
        return floor,ceil 

