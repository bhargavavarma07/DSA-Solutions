class Solution:
    def getFloorAndCeil(self, x: int, arr: list) -> list:
        # code here
        floor=-1
        ceil=-1
        for i in arr:
            if(x>=i):
                if(floor==-1):
                    floor=i
                floor=max(i,floor)
            if(x<=i):
                if(ceil==-1):
                    ceil=i
                ceil=min(ceil,i)
        return floor,ceil 
