class Solution:
    def rowWithMax1s(self, arr):
        # code here
        Max1s=-1
        Max1sFind=-1
        for i in range(len(arr)):
            low=0
            high=len(arr[0])-1
            while(low<=high):
                mid=(low+high)//2
                if(arr[i][mid]==0):
                    low=mid+1
                else:
                    high=mid-1
            if(len(arr[0])-low==0):
                No1s=0
            else:
                No1s=len(arr[0])-high
            if(No1s>Max1s):
                Max1s=No1s
                Max1sFind=i
        #print(Max1s)    
        if(Max1s==0):
            return -1
        
        return Max1sFind
